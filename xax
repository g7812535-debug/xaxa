from turtle import *
class Sprite(Turtle):
    def __init__(self, x, y, step=10, shape='turtle', color='red'): 
        super().__init__()
        self.penup()
        self.speed(0)
        self.goto(x, y)
        self.color(color)
        self.shape(shape)
        self.step = step
        self.points = 0
 
    def move_up(self):
        self.goto(self.xcor(), self.ycor() + self.step)
    def move_right(self):
        self.goto(self.xcor() + self.step, self.ycor())
sprite = Sprite(0, 0)  
sprite.move_up()     
sprite.move_right()    

