def staff_min_efficiency(staff):
    min_efficiency = float('inf') 
    worst_employee = None          
    
    for employee, info in staff.items():
        efficiency = info['эффективность']
        if efficiency < min_efficiency:
            min_efficiency = efficiency
            worst_employee = employee
            
    return worst_employee, min_efficiency

def staff_max_efficiency(staff):
    max_efficiency = float('-inf')  
    best_employee = None           
    
    for employee, info in staff.items():
        efficiency = info['эффективность']
        if efficiency > max_efficiency:
            max_efficiency = efficiency
            best_employee = employee
            
    return best_employee, max_efficiency

